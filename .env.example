# Copy this file to .env.local and fill in your values.

# Resend API key — https://resend.com → API Keys.
# IMPORTANT: must be "Full access" (not "Sending access only") so the
# newsletter can add contacts to your audience. Starts with "re_".
RESEND_API_KEY=

# Resend Audience ID for the newsletter — https://resend.com → Audiences.
# Create an audience, open it, copy its ID here.
RESEND_AUDIENCE_ID=

# NOTE: inquiry from/to addresses are configured in
# src/app/api/enquiry/route.ts (info@ / inquiries@adventureexpertsgeorgia.com)
# and are no longer read from the environment.
